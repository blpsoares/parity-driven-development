#!/usr/bin/env bash
# pdd — Parity-Driven Development CLI (stable wrapper). No npm involved.
#
# Runs the dashboard with whatever you have: Node (via the committed dist/pdd.js)
# or Bun (via the TypeScript source). It resolves the install location dynamically
# so it survives `claude plugin update`. Install once (see scripts/install-cli.sh).
set -euo pipefail

# Candidate package roots, newest plugin-cache version first, then the git clone.
cache_root="${HOME}/.claude/plugins/cache/parity-driven-development/pdd"
clone_root="${PDD_HOME:-$HOME/.pdd}/parity-driven-development"
roots=()
while IFS= read -r d; do roots+=("$d"); done < <(ls -d "${cache_root}"/*/ 2>/dev/null | sort -V -r)
roots+=("${clone_root}")

pick_root=""
for r in "${roots[@]}"; do
  [ -f "${r}/dist/pdd.js" ] || [ -f "${r}/scripts/pdd/index.ts" ] || continue
  pick_root="${r}"
  break
done

if [ -z "${pick_root}" ]; then
  echo "pdd: CLI not found. Install with one of:" >&2
  echo "  claude plugin install pdd@parity-driven-development                (Claude Code)" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/blpsoares/parity-driven-development/main/install.sh | bash -s -- <harness>" >&2
  exit 127
fi

# Prefer Node running the built bundle (no build step, no npm). Fall back to Bun
# running the source. If neither runtime is present, say so.
if command -v node >/dev/null 2>&1 && [ -f "${pick_root}/dist/pdd.js" ]; then
  exec node "${pick_root}/dist/pdd.js" "$@"
elif command -v bun >/dev/null 2>&1 && [ -f "${pick_root}/scripts/pdd/index.ts" ]; then
  exec bun run "${pick_root}/scripts/pdd/index.ts" "$@"
elif command -v node >/dev/null 2>&1 && [ -f "${pick_root}/scripts/pdd/index.ts" ] && [ -f "${pick_root}/dist/pdd.js" ]; then
  exec node "${pick_root}/dist/pdd.js" "$@"
else
  echo "pdd: needs Node or Bun to run the dashboard (the PDD method itself needs neither)." >&2
  echo "     Install Node (https://nodejs.org) or Bun (https://bun.sh), or use /audit-status in your agent." >&2
  exit 127
fi
